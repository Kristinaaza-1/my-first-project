# Скопируйте этот файл в .env и заполните реальными значениями

TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=

# Вариант 1: путь к скачанному JSON-файлу сервис-аккаунта (для локального запуска)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Вариант 2: содержимое JSON-файла целиком одной строкой (удобно для Railway/облака) — если заполнено, имеет приоритет
GOOGLE_SERVICE_ACCOUNT_JSON=

GOOGLE_SHEET_ID=
GOOGLE_CALENDAR_ID=

MASTER_TELEGRAM_CHAT_ID=
